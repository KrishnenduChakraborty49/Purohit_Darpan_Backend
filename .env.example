# ===================================================================
# Purohit Darpan — Backend Environment Variables
# Copy to .env or set in your OS environment
# ===================================================================

# ── Database ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=purohit_darpan
DB_USERNAME=root
DB_PASSWORD=your_mysql_password

# ── JWT ──────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=change_me_to_a_64_char_random_base64_string_in_production_env_now
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ── OpenAI (Spring AI) ───────────────────────────────────────────
OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# ── Firebase Admin SDK ───────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json
FIREBASE_PROJECT_ID=your-firebase-project-id

# ── Panchang API ─────────────────────────────────────────────────
PANCHANG_API_URL=https://api.prokerala.com/v2/astrology
PANCHANG_API_KEY=your_panchang_api_key
PANCHANG_USE_MOCK=true

# ── CORS ─────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Server ───────────────────────────────────────────────────────
SERVER_PORT=8080

# ── Spring Profile ────────────────────────────────────────────────
# Options: dev, prod
SPRING_PROFILES_ACTIVE=dev
